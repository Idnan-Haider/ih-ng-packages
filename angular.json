{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ih-ng-notification": {
      "projectType": "library",
      "root": "projects/ih-ng-notification",
      "sourceRoot": "projects/ih-ng-notification/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/ih-ng-notification/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/ih-ng-notification/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ih-ng-notification/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "main": "projects/ih-ng-notification/src/test.ts",
            "tsConfig": "projects/ih-ng-notification/tsconfig.spec.json",
            "karmaConfig": "projects/ih-ng-notification/karma.conf.js"
          }
        }
      }
    },
    "ih-ng-css-utility": {
      "projectType": "library",
      "root": "projects/ih-ng-css-utility",
      "sourceRoot": "projects/ih-ng-css-utility/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/ih-ng-css-utility/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/ih-ng-css-utility/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ih-ng-css-utility/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:karma",
          "options": {
            "main": "projects/ih-ng-css-utility/src/test.ts",
            "tsConfig": "projects/ih-ng-css-utility/tsconfig.spec.json",
            "karmaConfig": "projects/ih-ng-css-utility/karma.conf.js"
          }
        }
      }
    },
    "storybook": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/storybook",
      "sourceRoot": "projects/storybook/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/storybook/src/main.ts",
            "tsConfig": "projects/storybook/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/storybook/public"
              }
            ],
            "styles": [
              "projects/storybook/src/styles.scss"
            ],
            "stylePreprocessorOptions": {
              "includePaths": [
                "projects/ih-ng-css-utility/src/lib"
              ]
            }
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "storybook:build:production"
            },
            "development": {
              "buildTarget": "storybook:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "storybook:build",
            "compodoc": false,
            "port": 6006
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "storybook:build",
            "compodoc": false,
            "outputDir": "dist/storybook/storybook"
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "c15de7b2-56a3-4d9d-b723-b592b599fdf3"
  },
  "schematics": {
    "@schematics/angular:component": {
      "type": "component"
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  }
}